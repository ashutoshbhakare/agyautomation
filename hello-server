apiVersion: apps/v1
kind: Deployment
metadata:
  name: hello-server
  namespace: production
  labels:
    app: hello-server
spec:
  replicas: 2
  selector:
    matchLabels:
      app: hello-server
  template:
    metadata:
      labels:
        app: hello-server
    spec:
      containers:
        - name: hello-server
          image: gcr.io/PROJECT_ID/hello-server:latest
          ports:
            - containerPort: 8080
          resources:
            requests:
              cpu: "250m"
              memory: "256Mi"
            limits:
              cpu: "500m"
              memory: "512Mi"
          readinessProbe:
            httpGet:
              path: /healthz
              port: 8080
            initialDelaySeconds: 5
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: /healthz
              port: 8080
            initialDelaySeconds: 10
            periodSeconds: 20
---
apiVersion: v1
kind: Service
metadata:
  name: hello-server
  namespace: production
  labels:
    app: hello-server
spec:
  type: ClusterIP
  selector:
    app: hello-server
  ports:
    - port: 80
      targetPort: 8080
      protocol: TCP
